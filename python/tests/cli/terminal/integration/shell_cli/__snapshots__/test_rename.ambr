# name: TestScriptRename.test_rename_with_explicit_id[screen-bash]
  '''
  # Given session (name="OldName")
  # Execute: SHELL=bash bash lightningterminal.sh status --id oldname-XXXXXXXX
  OldName - bash (detached, id=oldname-XXXXXXXX)
  
  # Execute: SHELL=bash bash lightningterminal.sh rename --id oldname-XXXXXXXX NewName
  # Execute: SHELL=bash bash lightningterminal.sh status --id oldname-XXXXXXXX
  NewName - bash (detached, id=oldname-XXXXXXXX)
  
  
  '''
# ---
# name: TestScriptRename.test_rename_with_explicit_id[screen-zsh]
  '''
  # Given session (name="OldName")
  # Execute: SHELL=zsh zsh lightningterminal.sh status --id oldname-XXXXXXXX
  OldName - zsh (detached, id=oldname-XXXXXXXX)
  
  # Execute: SHELL=zsh zsh lightningterminal.sh rename --id oldname-XXXXXXXX NewName
  # Execute: SHELL=zsh zsh lightningterminal.sh status --id oldname-XXXXXXXX
  NewName - zsh (detached, id=oldname-XXXXXXXX)
  
  
  '''
