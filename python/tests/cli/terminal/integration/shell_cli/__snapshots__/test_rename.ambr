# name: TestScriptRename.test_rename_shows_in_ls[screen-bash]
  '''
  # Given session (name="Before")
  # Execute: SHELL=bash bash lightningterminal.sh rename --id before-XXXXXXXX After
  # Execute: SHELL=bash bash lightningterminal.sh ls
  After - bash (detached, id=before-XXXXXXXX)
  
  
  '''
# ---
# name: TestScriptRename.test_rename_shows_in_ls[screen-zsh]
  '''
  # Given session (name="Before")
  # Execute: SHELL=zsh zsh lightningterminal.sh rename --id before-XXXXXXXX After
  # Execute: SHELL=zsh zsh lightningterminal.sh ls
  After - zsh (detached, id=before-XXXXXXXX)
  
  
  '''
