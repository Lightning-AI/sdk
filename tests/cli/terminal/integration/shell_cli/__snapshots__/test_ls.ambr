# serializer version: 1
# name: TestLtLs.test_lt_ls[screen-bash]
  '''
  # Given session (name="ListMe")
  # [pty1] Start: bash lightningterminal.sh attach --id listme-XXXXXXXX
  # [pty1] Send: lt ls\n
  # [pty1] Snapshot - lt ls output
  $ lt ls
  ListMe - lt (attached, id=listme-XXXXXXXX)
  $
  
  
  '''
# ---
# name: TestLtLs.test_lt_ls[screen-zsh]
  '''
  # Given session (name="ListMe")
  # [pty1] Start: zsh lightningterminal.sh attach --id listme-XXXXXXXX
  # [pty1] Send: lt ls\n
  # [pty1] Snapshot - lt ls output
  $ lt ls
  ListMe - lt (attached, id=listme-XXXXXXXX)
  $
  
  
  '''
# ---
