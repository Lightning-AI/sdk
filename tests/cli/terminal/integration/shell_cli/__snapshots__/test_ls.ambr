# name: TestScriptLsFormat.test_oneliner_vs_raw[screen-bash]
  '''
  # Given session (name="Backend")
  # Execute: SHELL=bash bash lightningterminal.sh ls
  Backend - bash (detached, id=backend-XXXXXXXX)
  
  # Execute: SHELL=bash bash lightningterminal.sh ls --raw
  session_id: backend-XXXXXXXX
  pid: XXXXXXX
  status: detached
  terminal_name: Backend
  default_name: term-1
  display_label: Backend (bash)
  last_command: bash
  created: XXXX-XX-XXTXX:XX:XX.XXXXXXXXX+XX:XX
  
  
  '''
