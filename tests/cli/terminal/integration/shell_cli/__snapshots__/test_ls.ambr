# name: TestScriptLs.test_single_anonymous_session[screen-bash]
  '''
  # Given session (name=<anon>)
  # Execute: SHELL=bash bash lightningterminal.sh ls
  term-1 - bash (detached, id=session-XXXXXXXX)
  
  
  '''
# ---
