  # [pty1] Send: lt status --id inner-XXXXXXXX\n
  # [pty1] Snapshot - inner detached after lt detach
  $ lt attach --id inner-XXXXXXXX
  [detached from XXXXXXX.inner-XXXXXXXX]
  $ lt status --id inner-XXXXXXXX
  Inner - lt (detached, id=inner-XXXXXXXX)
  $
  
  
  '''
