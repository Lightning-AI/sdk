# name: TestKeyboardDetach.test_ctrl_t_d_detaches_inner_not_outer[screen-bash]
  '''
  # Given session (name="Outer")
  # Given session (name="Inner")
  # [pty1] Start: bash lightningterminal.sh attach --id outer-XXXXXXXX
  # [pty1] Send: lt attach --id inner-XXXXXXXX\n
  # [pty1] Send: lt status --id inner-XXXXXXXX\n
  # [pty1] Send: d
  # [pty1] Send: lt status --id inner-XXXXXXXX\n
  # [pty1] Send: lt status --id outer-XXXXXXXX\n
  # [pty1] Snapshot - back in outer after Ctrl+T D
  $ lt attach --id inner-XXXXXXXX
  [detached from XXXXXXX.inner-XXXXXXXX]
  $ lt status --id inner-XXXXXXXX
  Inner - lt (detached, id=inner-XXXXXXXX)
  $ lt status --id outer-XXXXXXXX
  Outer - lt (attached, id=outer-XXXXXXXX)
  $
  
  
  '''
# ---
