# name: TestNestedDetach.test_three_levels_deep[screen-bash]
  '''
  # Given session (name="LevelA")
  # Given session (name="LevelB")
  # Given session (name="LevelC")
  # [pty1] Start: bash lightningterminal.sh attach --id levela-XXXXXXXX
  # [pty1] Send: lt attach --id levelb-XXXXXXXX\n
  # [pty1] Send: lt attach --id levelc-XXXXXXXX\n
  # [pty1] Send: echo IN_LEVEL_C\n
  # [pty1] Snapshot - in C
  $ echo IN_LEVEL_C
  IN_LEVEL_C
  $
  
  # [pty1] Send: lt detach\n
  # [pty1] Snapshot - back in B
  $ lt attach --id levelc-XXXXXXXX
  [detached from XXXXXXX.levelc-XXXXXXXX]
  $
  
  # [pty1] Send: lt detach\n
  # [pty1] Snapshot - back in A
  $ lt attach --id levelb-XXXXXXXX
  [detached from XXXXXXX.levelb-XXXXXXXX]
  $
  
  
  '''
# ---
